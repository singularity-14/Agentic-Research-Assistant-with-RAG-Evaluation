# ============================================================
# CERN Knowledge Navigator — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── LangSmith Observability ─────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=cern-knowledge-navigator

# ── Groq LLM ────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
# Model for answer generation (large, high quality)
GROQ_MODEL=llama-3.3-70b-versatile
# Model for RAGAS evaluation judge (fast, economical)
GROQ_JUDGE_MODEL=llama-3.1-8b-instant

# ── Embeddings (Local HuggingFace — no API key needed) ──────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# ── Vector Store (FAISS — local) ────────────────────────────
FAISS_INDEX_PATH=data/faiss_index
INDEX_NAME=cern_papers

# ── Data Ingestion ───────────────────────────────────────────
MAX_RESULTS_DEFAULT=500
ARXIV_DELAY_SECONDS=3.0
# Comma-separated arXiv categories
ARXIV_CATEGORIES=hep-ex,hep-ph,physics.acc-ph

# ── MCP Server ───────────────────────────────────────────────
MCP_AUTH_TOKEN=changeme-replace-with-secure-random-token
MCP_HOST=0.0.0.0
MCP_PORT=8001

# ── FastAPI REST Service ─────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── RAG Chain ────────────────────────────────────────────────
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5
ENABLE_HYDE=true
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Evaluation ───────────────────────────────────────────────
FAITHFULNESS_THRESHOLD=0.8
EVAL_RESULTS_PATH=data/evaluation/results
GOLDEN_QA_PATH=data/evaluation/golden_qa.json
